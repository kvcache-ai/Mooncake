  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Memory Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "master_allocated_bytes / master_total_capacity_bytes",
          "legendFormat": "DRAM Usage",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Key Count",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 3, "x": 6, "y": 0 },
      "id": 2,
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "targets": [
        {
          "expr": "master_key_count",
          "legendFormat": "Keys",
          "refId": "A"
        }
      ]
    },
